/* セクション共通 */
.section-block { margin-bottom: 50px; padding: 35px 40px; border-radius: 32px; background: var(--surface-strong); box-shadow: 0 10px 30px rgba(0, 80, 120, 0.06); }
.section-header { display: flex; align-items: center; gap: 18px; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 2px solid rgba(0, 136, 169, 0.1); position: relative; }
