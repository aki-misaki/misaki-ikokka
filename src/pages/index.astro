.archive-toggle::after, .policy-toggle::after { width: 2px; height: 12px; transition: 0.3s; }
.modern-details[open] .archive-toggle::after, .modern-details[open] .policy-toggle::after { transform: translate(-50%, -50%) rotate(90deg) scaleY(0); }

/* アーカイブ用グリッド */
