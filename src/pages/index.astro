.update-date { display: inline-flex; align-items: center; padding: 4px 14px; margin-bottom: 20px; background: #f4f7f9; color: var(--text-soft); border: 1px solid rgba(44, 62, 80, 0.08); border-radius: 50px; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.05em; } .update-date::before { content: "🕒"; margin-right: 6px; font-size: 0.9rem; }

/* 追加：市場セクションのシンプルなリスト化とボタン */
.simple-list { margin: 0; padding-left: 1.5em; color: var(--text); font-size: 0.95rem; }
.simple-list li { margin-bottom: 10px; }
.compact-btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 700; font-size: 0.95rem; color: var(--blue) !important; background: #fff; border: 1px solid var(--blue-soft); padding: 10px 22px; border-radius: 50px; box-shadow: 0 4px 10px rgba(9, 132, 227, 0.08); text-decoration: none !important; transition: all 0.25s ease; }
.compact-btn:hover { background: var(--blue-soft); border-color: var(--blue); transform: translateY(-2px); box-shadow: 0 6px 15px rgba(9, 132, 227, 0.15); }

/* 埋め込みエリア */
