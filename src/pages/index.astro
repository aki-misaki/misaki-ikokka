<script>
  document.addEventListener("DOMContentLoaded", async () => {
    // 👇 追加：XSS対策用のエスケープ関数
    const escapeHtml = (str = "") =>
      String(str)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    // 👇 追加：安全なURLチェック関数
    const safeUrl = (url = "") => {
      try {
        const u = new URL(url);
        return ["http:", "https:"].includes(u.protocol) ? u.href : "";
      } catch {
        return "";
      }
    };

    const bgImages = [
      '18.jpg', '7.jpg', '8.JPG', '10.JPG', '11.JPG', 
      '12.JPG', '14.JPG', '16.jpg', '17.jpg', '5.jpg'
    ];
    
    const randomImg = bgImages[Math.floor(Math.random() * bgImages.length)];
    const heroBg = document.querySelector('.hero-bg');
    
    if (heroBg) {
      heroBg.style.backgroundImage = `linear-gradient(180deg, rgba(0, 50, 80, 0.2), rgba(0, 90, 120, 0.6)), url('https://cdn.jsdelivr.net/gh/aki-misaki/misaki-ikokka@main/images/${randomImg}')`;
    }
    
    const gasUrl = "https://script.google.com/macros/s/AKfycbyfN0Ng6HhjZ1tDPKSRNYce-3eklsHTpZwJDb4dptJlEqofg0KGntWp77rCyjDUNFu8/exec";
    
    try {
      const response = await fetch(`${gasUrl}?mode=json&view=both`);
      const data = await response.json();
      
      if (!data.ok) throw new Error("APIエラー");

      const updateDateEl = document.getElementById("calendar-update-date");
      if (updateDateEl) {
        if (data.meta && data.meta.lastUpdated) {
          updateDateEl.innerText = `最終確認日：${escapeHtml(data.meta.lastUpdated)}`;
        }
      }

      const now = new Date(new Date().toLocaleString("en-US", {timeZone: "Asia/Tokyo"}));
      const tYear = now.getFullYear();
      const tMonth = String(now.getMonth() + 1).padStart(2, '0');
      const tDate = String(now.getDate()).padStart(2, '0');
      const todayIsoStr = `${tYear}-${tMonth}-${tDate}`;
      const todayZero = new Date(tYear, now.getMonth(), now.getDate()).getTime();

      let todayEvents = [];

      if (data.monthly) {
        data.monthly.forEach(m => {
          m.events.forEach(ev => {
            if (ev.startIso && ev.startIso.startsWith(todayIsoStr)) {
              todayEvents.push(ev);
            }
          });
        });
      }

      if (data.spanEvents) {
        data.spanEvents.forEach(ev => {
          const parseDateJP = (dateStr) => {
            const match = dateStr.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
            if (match) {
              return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3])).getTime();
            }
            return 0;
          };
          const sTime = parseDateJP(ev.start);
          const eTime = parseDateJP(ev.end);
          if (sTime > 0 && eTime > 0 && todayZero >= sTime && todayZero <= eTime) {
            todayEvents.push(ev);
          }
        });
      }

      let todayHtml = "";
      if (todayEvents.length === 0) {
        todayHtml = `<p style="font-weight: 700; color: var(--text-soft); margin: 0; padding: 18px; background: #fff; border-radius: 12px; text-align: center; border: 1px dashed #cbd5e1;">イベントの予定はありません</p>`;
      } else {
        todayHtml = `<div class="today-grid">`;
        todayEvents.forEach(ev => {
          // 👇 修正：空文字チェック付きの安全なURL生成
          const timeText = ev.time ? escapeHtml(ev.time) : "終日 / 複数日";
          const eLoc = escapeHtml(ev.location || "場所未定");
          const eTitle = escapeHtml(ev.title);
          
          const locUrl = safeUrl(ev.locationUrl);
          const titleUrl = safeUrl(ev.url);

          const locationHtml = locUrl 
            ? `<a href="${locUrl}" target="_blank" rel="noopener noreferrer">${eLoc}</a>` 
            : eLoc;
          const titleHtml = titleUrl 
            ? `<a href="${titleUrl}" target="_blank" rel="noopener noreferrer" style="color:var(--text);">${eTitle}</a>` 
            : eTitle;

          todayHtml += `
            <div class="today-card">
              <div class="today-title">${titleHtml}</div>
              <div class="today-info">
                <span>🕒 ${timeText}</span>
                <span>📍 ${locationHtml}</span>
              </div>
            </div>
          `;
        });
        todayHtml += `</div>`;
      }
      const todayContainer = document.getElementById("today-container");
      if (todayContainer) todayContainer.innerHTML = todayHtml;

      let monthlyHtml = "";
      if (!data.monthly || data.monthly.length === 0) {
        monthlyHtml = '<p style="color: #8395a7;">期間内に該当する予定はありません。</p>';
      } else {
        monthlyHtml += `<div class="monthly-scroll-wrapper">`; 
        data.monthly.forEach(monthGroup => {
          monthlyHtml += `<h4 class="monthly-heading">${escapeHtml(monthGroup.month)}</h4>`;
          monthlyHtml += `
            <table class="monthly-table">
              <thead>
                <tr>
                  <th>イベント名</th><th>日付</th><th>時間</th><th>場所</th><th>リンク</th>
                </tr>
              </thead>
              <tbody>
          `;
          monthGroup.events.forEach(ev => {
            // 👇 修正：空文字チェック付きの安全なURL生成
            const eLoc = escapeHtml(ev.location);
            const eTitle = escapeHtml(ev.title);
            const eText = escapeHtml(ev.text);
            const eDate = escapeHtml(ev.date);
            const eTime = escapeHtml(ev.time);

            const locUrl = safeUrl(ev.locationUrl);
            const linkUrl = safeUrl(ev.url);

            const locationHtml = locUrl 
              ? `<a href="${locUrl}" target="_blank" rel="noopener noreferrer">${eLoc}</a>` 
              : eLoc;
            const linkHtml = linkUrl 
              ? `<a href="${linkUrl}" target="_blank" rel="noopener noreferrer">${eText}</a>` 
              : eText;

            monthlyHtml += `
              <tr>
                <td class="event-title-cell" data-label="イベント名">${eTitle}</td>
                <td data-label="日付">${eDate}</td>
                <td data-label="時間">${eTime}</td>
                <td data-label="場所">${locationHtml}</td>
                <td data-label="リンク">${linkHtml}</td>
              </tr>
            `;
          });
          monthlyHtml += `</tbody></table>`;
        });
        monthlyHtml += `</div>`;
      }
      const monthlyContainer = document.getElementById("monthly-container");
      if (monthlyContainer) monthlyContainer.innerHTML = monthlyHtml;

      let spanHtml = "";
      if (!data.spanEvents || data.spanEvents.length === 0) {
        spanHtml = '<p style="color: #8395a7;">期間内に該当する予定はありません。</p>';
      } else {
        spanHtml += `<div class="card-container">`;
        data.spanEvents.forEach(ev => {
          // 👇 修正：空文字チェック付きの安全なURL生成
          const dateText = (ev.start === ev.end) ? escapeHtml(ev.start) : `${escapeHtml(ev.start)} - ${escapeHtml(ev.end)}`;
          const eLoc = escapeHtml(ev.location);
          const eTitle = escapeHtml(ev.title);
          const eText = escapeHtml(ev.text);

          const locUrl = safeUrl(ev.locationUrl);
          const linkUrl = safeUrl(ev.url);

          const locationHtml = locUrl 
            ? `<a href="${locUrl}" target="_blank" rel="noopener noreferrer">${eLoc}</a>` 
            : `<span>${eLoc}</span>`;
          const linkHtml = linkUrl 
            ? `<a href="${linkUrl}" target="_blank" rel="noopener noreferrer">${eText}</a>` 
            : `<span>${eText}</span>`;

          spanHtml += `
            <div class="event-card">
              <div class="card-title">${eTitle}</div>
              <div class="card-details">
                <p><span class="card-icon" aria-hidden="true">🗓️</span><span>${dateText}</span></p>
                ${ev.location ? `<p><span class="card-icon" aria-hidden="true">📍</span>${locationHtml}</p>` : ''}
                ${ev.text ? `<p><span class="card-icon" aria-hidden="true">🔗</span>${linkHtml}</p>` : ''}
              </div>
            </div>
          `;
        });
        spanHtml += `</div>`;
      }
      const spanContainer = document.getElementById("span-container");
      if (spanContainer) spanContainer.innerHTML = spanHtml;

      const loadingMessage = document.getElementById("loading-message");
      if (loadingMessage) loadingMessage.style.display = "none";
      
      const calendarContent = document.getElementById("calendar-content");
      if (calendarContent) calendarContent.style.display = "block";

    } catch (error) {
      console.error("データの取得に失敗しました:", error);
      
      const loadingMsg = document.getElementById("loading-message");
      if (loadingMsg) loadingMsg.style.display = "none";
      
      const todayLoading = document.getElementById("today-loading");
      if (todayLoading) todayLoading.style.display = "none";
      
      const errorMsg = document.getElementById("error-message");
      if (errorMsg) errorMsg.style.display = "block";

      const todayContainer = document.getElementById("today-container");
      if (todayContainer) {
        todayContainer.innerHTML = `
          <p style="font-weight: 700; color: var(--text-soft); margin: 0; padding: 18px; background: #fff; border-radius: 12px; text-align: center; border: 1px dashed #cbd5e1;">
            本日のイベント情報を取得できませんでした。下のカレンダーまたは公式情報をご確認ください。
          </p>
        `;
      }
    }
  });
</script>

<style is:global>
html, body { overflow-x: hidden; }

