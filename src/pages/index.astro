/* 導入部・スリム化 */
.intro-simple { margin: -12px auto 36px; padding: 18px 22px; max-width: 920px; text-align: left; background: rgba(255, 255, 255, 0.72); border: 1px solid rgba(0, 136, 169, 0.12); border-radius: 18px; box-shadow: 0 6px 18px rgba(0, 80, 120, 0.04); }
