<script>
  document.addEventListener("DOMContentLoaded", async () => {
    const bgImages = [
      '18.jpg',
      '7.jpg',
      '8.JPG',
      '10.JPG',
      '11.JPG',
      '12.JPG',
      '14.JPG',
      '16.jpg',
      '17.jpg',
      '5.jpg'      // いくらでも増やせます（最後だけカンマなし）
    ];
    
    // ランダムに1枚選ぶくじ引き
    const randomImg = bgImages[Math.floor(Math.random() * bgImages.length)];
    const heroBg = document.querySelector('.hero-bg');
    
    if (heroBg) {
      // 選ばれた写真を背景に設定（暗くなるフィルターもそのまま適用）
      heroBg.style.backgroundImage = `linear-gradient(180deg, rgba(0, 50, 80, 0.2), rgba(0, 90, 120, 0.6)), url('https://cdn.jsdelivr.net/gh/aki-misaki/misaki-ikokka@main/images/${randomImg}')`;
    }
    
    const gasUrl = "https://script.google.com/macros/s/AKfycbyfN0Ng6HhjZ1tDPKSRNYce-3eklsHTpZwJDb4dptJlEqofg0KGntWp77rCyjDUNFu8/exec";
    
    try {
      const response = await fetch(`${gasUrl}?mode=json&view=both`);
      const data = await response.json();
      
      if (!data.ok) throw new Error("APIエラー");

      // --- 月ごとイベント（テーブル）の組み立て ---
      let monthlyHtml = "";
      if (!data.monthly || data.monthly.length === 0) {
        monthlyHtml = '<p style="color: #8395a7;">期間内に該当する予定はありません。</p>';
      } else {
        monthlyHtml += `<div class="monthly-scroll-wrapper">`; 
        data.monthly.forEach(monthGroup => {
          monthlyHtml += `<h4 class="monthly-heading">${monthGroup.month}</h4>`;
          monthlyHtml += `
            <table class="monthly-table">
              <thead>
                <tr>
                  <th>イベント名</th><th>日付</th><th>時間</th><th>場所</th><th>リンク</th>
                </tr>
              </thead>
              <tbody>
          `;
          monthGroup.events.forEach(ev => {
            const locationHtml = ev.locationUrl 
              ? `<a href="${ev.locationUrl}" target="_blank" rel="noopener noreferrer">${ev.location}</a>` 
              : ev.location;
            const linkHtml = ev.url 
              ? `<a href="${ev.url}" target="_blank" rel="noopener noreferrer">${ev.text}</a>` 
              : ev.text;

            // 💡 tdの順番も変更し、イベント名に専用のクラス(event-title-cell)を付与
            monthlyHtml += `
              <tr>
                <td class="event-title-cell" data-label="イベント名">${ev.title}</td>
                <td data-label="日付">${ev.date}</td>
                <td data-label="時間">${ev.time}</td>
                <td data-label="場所">${locationHtml}</td>
                <td data-label="リンク">${linkHtml}</td>
              </tr>
            `;
          });
          monthlyHtml += `</tbody></table>`;
        });
        monthlyHtml += `</div>`;
      }
      document.getElementById("monthly-container").innerHTML = monthlyHtml;

      // --- 日またぎイベント（カード）の組み立て ---
      let spanHtml = "";
      if (!data.spanEvents || data.spanEvents.length === 0) {
        spanHtml = '<p style="color: #8395a7;">期間内に該当する予定はありません。</p>';
      } else {
        spanHtml += `<div class="card-container">`;
        data.spanEvents.forEach(ev => {
          const dateText = (ev.start === ev.end) ? ev.start : `${ev.start} - ${ev.end}`;
          const locationHtml = ev.locationUrl 
            ? `<a href="${ev.locationUrl}" target="_blank" rel="noopener noreferrer">${ev.location}</a>` 
            : `<span>${ev.location}</span>`;
          const linkHtml = ev.url 
            ? `<a href="${ev.url}" target="_blank" rel="noopener noreferrer">${ev.text}</a>` 
            : `<span>${ev.text}</span>`;

          spanHtml += `
            <div class="event-card">
              <div class="card-title">${ev.title}</div>
              <div class="card-details">
                <p><span class="card-icon" aria-hidden="true">🗓️</span><span>${dateText}</span></p>
                ${ev.location ? `<p><span class="card-icon" aria-hidden="true">📍</span>${locationHtml}</p>` : ''}
                ${ev.text ? `<p><span class="card-icon" aria-hidden="true">🔗</span>${linkHtml}</p>` : ''}
              </div>
            </div>
          `;
        });
        spanHtml += `</div>`;
      }
      document.getElementById("span-container").innerHTML = spanHtml;

      document.getElementById("loading-message").style.display = "none";
      document.getElementById("calendar-content").style.display = "block";

    } catch (error) {
      console.error("データの取得に失敗しました:", error);
      document.getElementById("loading-message").style.display = "none";
      document.getElementById("error-message").style.display = "block";
    }
  });
</script>

