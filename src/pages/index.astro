.icon-blue { color: var(--blue); } .icon-green { color: var(--green); } .icon-orange { color: var(--orange); }
.section-title { margin: 0; font-size: clamp(1.5rem, 3vw, 1.95rem); line-height: 1.3; font-weight: 900; color: var(--brand-strong); letter-spacing: 0.03em; }

