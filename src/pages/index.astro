/* アコーディオン切り替えアイコン（アーカイブ ＆ プライバシーポリシー共通） */
.modern-details summary { display: flex; align-items: center; justify-content: space-between; cursor: pointer; font-size: 1.05rem; font-weight: 800; color: var(--brand); padding: 15px 20px; list-style: none; }
.archive-toggle, .policy-toggle { position: relative; width: 28px; height: 28px; border-radius: 50%; background: var(--brand-soft); flex: 0 0 28px; }
.archive-toggle::before, .archive-toggle::after, .policy-toggle::before, .policy-toggle::after { content: ""; position: absolute; left: 50%; top: 50%; background: var(--brand); transform: translate(-50%, -50%); }
