.footer-logo { margin-bottom: 15px; color: #fff; font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; }

/* 📱 スマホ向けレスポンシブ */
@media screen and (max-width:768px) {
  .container { width: calc(100% - 30px); }
  .hero-header { min-height: 340px; }
  .hero-bg { background-position: center top; }
  .hero-text { backdrop-filter: none; -webkit-backdrop-filter: none; background: rgba(10, 30, 50, 0.5); padding: 25px 15px; box-shadow: none; }
  
  /* 明るい写真でも文字がクッキリ読めるように文字影を強化 */
  .hero-text h1, .hero-lead, .hero-subtitle { text-shadow: 0 2px 10px rgba(0, 0, 0, 0.45); }
  
  .intro-simple { padding: 15px; margin-bottom: 30px; }
  .section-block { padding: 25px 20px; border-radius: 24px; }
  
  .monthly-table thead { display: none; }
  .monthly-table tr { display: block; margin-bottom: 12px; border: 1px solid #e0e6ed; border-radius: 12px; }
  .monthly-table td { display: block; padding-left: 75px; position: relative; border-bottom: 1px solid #f4f7f9; }
  .monthly-table td::before { content: attr(data-label); position: absolute; left: 15px; font-weight: 800; color: var(--text-soft); }
  .monthly-table td.event-title-cell { padding-left: 15px; background: #f4f7f9; font-weight: 900; }
  .monthly-table td.event-title-cell::before { display: none; }
  
  .contact-button { width: 100%; }
}
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
