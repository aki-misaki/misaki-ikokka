<script>
  document.addEventListener("DOMContentLoaded", async () => {
    const escapeHtml = (str = "") =>
      String(str).replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;").replaceAll("'", "&#039;");
    const safeUrl = (url = "") => {
      try { const u = new URL(url); return ["http:", "https:"].includes(u.protocol) ? u.href : ""; } catch { return ""; }
    };

    const bgImages = ['18.jpg', '7.jpg', '8.JPG', '10.JPG', '11.JPG', '12.JPG', '14.JPG', '16.jpg', '17.jpg', '5.jpg'];
    const randomImg = bgImages[Math.floor(Math.random() * bgImages.length)];
    const heroBg = document.querySelector('.hero-bg');
    if (heroBg) { heroBg.style.backgroundImage = `linear-gradient(180deg, rgba(0, 50, 80, 0.2), rgba(0, 90, 120, 0.6)), url('https://cdn.jsdelivr.net/gh/aki-misaki/misaki-ikokka@main/images/${randomImg}')`; }

    const gasUrl = "https://script.google.com/macros/s/AKfycbyfN0Ng6HhjZ1tDPKSRNYce-3eklsHTpZwJDb4dptJlEqofg0KGntWp77rCyjDUNFu8/exec";
    
    try {
      const response = await fetch(`${gasUrl}?mode=json&view=both`);
      const data = await response.json();
      if (!data.ok) throw new Error("APIエラー");

      const updateDateEl = document.getElementById("calendar-update-date");
      if (updateDateEl) {
        if (data.meta && data.meta.lastUpdated) { updateDateEl.innerText = `最終確認日：${escapeHtml(data.meta.lastUpdated)}`; }
        else { updateDateEl.innerText = "最終確認日：未取得 ※開催可否は必ず公式情報をご確認ください"; }
      }

      const now = new Date(new Date().toLocaleString("en-US", {timeZone: "Asia/Tokyo"}));
      const todayIsoStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
      const todayZero = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();

      let todayEvents = [];

      if (data.monthly) {
        data.monthly.forEach(m => { m.events.forEach(ev => { if (ev.startIso && ev.startIso.startsWith(todayIsoStr)) todayEvents.push(ev); }); });
      }
      if (data.spanEvents) {
        data.spanEvents.forEach(ev => {
          const parseDateJP = (s) => { const m = s.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/); return m ? new Date(Number(m[1]), Number(m[2])-1, Number(m[3])).getTime() : 0; };
          const sT = parseDateJP(ev.start); const eT = parseDateJP(ev.end);
          if (sT > 0 && eT > 0 && todayZero >= sT && todayZero <= eT) todayEvents.push(ev);
        });
      }

      let todayHtml = "";
      if (todayEvents.length === 0) {
        todayHtml = `<p style="font-weight: 700; color: var(--text-soft); margin: 0; padding: 18px; background: #fff; border-radius: 12px; text-align: center; border: 1px dashed #cbd5e1;">本日のイベント予定はありません。<br>直近の予定は下のイベント一覧をご確認ください。</p>`;
      } else {
        todayHtml = `<div class="card-container">`;
        todayEvents.forEach(ev => {
          const tTitle = escapeHtml(ev.title); const tLoc = escapeHtml(ev.location || "場所未定");
          const tUrl = safeUrl(ev.url); const lUrl = safeUrl(ev.locationUrl);
          const tLink = tUrl ? `<a href="${tUrl}" target="_blank" rel="noopener noreferrer">${tTitle}</a>` : tTitle;
          const lLink = lUrl ? `<a href="${lUrl}" target="_blank" rel="noopener noreferrer">${tLoc}</a>` : tLoc;
          todayHtml += `
            <div class="event-card blue-accent">
              <div class="card-title">${tLink}</div>
              <div class="card-details">
                <p><span class="card-icon" aria-hidden="true">🕒</span><span>${escapeHtml(ev.time || "終日 / 複数日")}</span></p>
                <p><span class="card-icon" aria-hidden="true">📍</span>${lLink}</p>
              </div>
            </div>`;
        });
        todayHtml += `</div>`;
      }
      const todayC = document.getElementById("today-container"); if (todayC) todayC.innerHTML = todayHtml;

      let monthlyHtml = "";
      if (data.monthly) {
        monthlyHtml += `<div class="monthly-scroll-wrapper">`;
        data.monthly.forEach(monthGroup => {
          monthlyHtml += `<h4 class="monthly-heading">${escapeHtml(monthGroup.month)}</h4><table class="monthly-table"><thead><tr><th>イベント名</th><th>日付</th><th>時間</th><th>場所</th><th>リンク</th></tr></thead><tbody>`;
          monthGroup.events.forEach(ev => {
            const lUrl = safeUrl(ev.locationUrl); const aUrl = safeUrl(ev.url);
            const lHtml = lUrl ? `<a href="${lUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(ev.location)}</a>` : escapeHtml(ev.location);
            const aHtml = aUrl ? `<a href="${aUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(ev.text)}</a>` : escapeHtml(ev.text);
            monthlyHtml += `
              <tr>
                <td class="event-title-cell" data-label="イベント名">${escapeHtml(ev.title)}</td>
                <td data-label="日付">${escapeHtml(ev.date)}</td>
                <td data-label="時間">${escapeHtml(ev.time)}</td>
                <td data-label="場所">${lHtml}</td>
                <td data-label="リンク">${aHtml}</td>
              </tr>
            `;
          });
          monthlyHtml += `</tbody></table>`;
        });
        monthlyHtml += `</div>`;
      }
      const monthlyC = document.getElementById("monthly-container"); if (monthlyC) monthlyC.innerHTML = monthlyHtml;

      let spanHtml = `<div class="card-container">`;
      if (data.spanEvents) {
        data.spanEvents.forEach(ev => {
          const lUrl = safeUrl(ev.locationUrl); const aUrl = safeUrl(ev.url);
          const lHtml = lUrl ? `<a href="${lUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(ev.location)}</a>` : escapeHtml(ev.location);
          const aHtml = aUrl ? `<a href="${aUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(ev.text)}</a>` : escapeHtml(ev.text);
          spanHtml += `<div class="event-card"><div class="card-title">${escapeHtml(ev.title)}</div><div class="card-details"><p><span class="card-icon">🗓️</span><span>${escapeHtml(ev.start)} - ${escapeHtml(ev.end)}</span></p><p><span class="card-icon">📍</span>${lHtml}</p><p><span class="card-icon">🔗</span>${aHtml}</p></div></div>`;
        });
      }
      spanHtml += `</div>`;
      const spanC = document.getElementById("span-container"); if (spanC) spanC.innerHTML = spanHtml;

      const loadingM = document.getElementById("loading-message"); if (loadingM) loadingM.style.display = "none";
      const calC = document.getElementById("calendar-content"); if (calC) calC.style.display = "block";

    } catch (err) {
      console.error(err);
      const loadingM = document.getElementById("loading-message"); if (loadingM) loadingM.style.display = "none";
      const todayL = document.getElementById("today-loading"); if (todayL) todayL.style.display = "none";
      const errorM = document.getElementById("error-message"); if (errorM) errorM.style.display = "block";
      const todayC = document.getElementById("today-container"); if (todayC) todayC.innerHTML = `<p style="font-weight: 700; color: var(--text-soft); margin: 0; padding: 18px; background: #fff; border-radius: 12px; text-align: center; border: 1px dashed #cbd5e1;">本日のイベント情報を取得できませんでした。下のカレンダーまたは公式情報をご確認ください。</p>`;
    }
  });
</script>

<style is:global>
html, body { overflow-x: hidden; }
